{
  "name": "receipt-scanner-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "expose": "ngrok http 3000",
    "tf:init": "terraform -chdir=terraform init",
    "tf:plan": "terraform -chdir=terraform plan",
    "tf:apply": "terraform -chdir=terraform apply",
    "tf:cleanup": "./scripts/tf-cleanup.sh",
    "tf:fmt": "terraform -chdir=terraform fmt",
    "git:cleanup-tags": "git fetch --tags && git tag -l | xargs -I {} git push origin --delete {} && git tag -l | xargs git tag -d",
    "job:check-reminders": "curl -X POST http://localhost:3000/api/scheduler/check-reminders"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "@line/bot-sdk": "^10.5.0",
    "@primevue/nuxt-module": "^4.5.4",
    "@primevue/themes": "^4.5.4",
    "chart.js": "^4.5.1",
    "csv-parse": "^6.1.0",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^10.5.0",
    "iconv-lite": "^0.7.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "nuxt": "^4.2.2",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "packageManager": "pnpm@9.12.3+sha1.4fb96925d434c491285182acf29803bb9aa2e6e5",
  "devDependencies": {
    "@types/csv-parse": "^1.2.5",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.2.3",
    "tsx": "^4.21.0"
  }
}
